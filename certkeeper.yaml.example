# ============================================================
# CertKeeper 配置文件模板
# 每个参数的含义和用途说明如下
# ============================================================

# --- ACME 证书颁发机构配置 ---
acme:
  # Let's Encrypt 服务端点
  # 生产环境: https://acme-v02.api.letsencrypt.org/directory
  # 测试环境: https://acme-staging-v02.api.letsencrypt.org/directory
  directory: https://acme-v02.api.letsencrypt.org/directory

  # 用于接收证书过期提醒的邮箱
  email: admin@example.com

  # ACME 账户密钥的本地存储路径
  account_key: ./data/account.key

# --- 自动续期调度 ---
scheduler:
  enabled: true          # 是否启用自动续期
  interval: daily        # 检查间隔: daily / weekly
  time: "03:00"          # 每天检查时间（24小时制）
  reminder_days: 30      # 证书剩余天数低于此值时发送到期提醒邮件

# --- 邮件通知配置 ---
# 配置后，证书到期提醒、续期/部署成功或失败都会发送邮件
notifications:
  email-notify:                        # ← 自定义名称
    type: smtp                         # 通知类型（目前仅支持 smtp）
    host: smtp.example.com             # SMTP 服务器地址
    port: 465                          # SMTP 端口（SSL: 465, TLS: 587）
    sender: certkeeper@example.com     # 发件人地址
    recipients: admin@example.com      # 收件人地址，多个用逗号分隔
    # username: ""                     # SMTP 认证用户名（可选）
    # password: ""                     # SMTP 认证密码（可选）
    use_ssl: true                      # 是否使用 SSL（默认 true）

# --- DNS 提供商 ---
# 用于 DNS-01 验证方式：自动添加/删除 DNS TXT 记录
# 可以配置多个，名称自定义（如 aliyun、cloudflare 等）
dns_providers:
  aliyun:                          # ← 自定义名称，在证书配置中引用
    type: aliyun                   # 提供商类型（目前仅支持 aliyun）
    access_key_id: ""              # 阿里云 AccessKey ID
    access_key_secret: ""          # 阿里云 AccessKey Secret

# --- 部署目标 ---
# 证书申请/续期后自动部署到这些目标
# 可以配置多个，名称自定义
deployers:
  # 方式一：通过 SSH 部署到 Nginx 服务器
  my-nginx:                        # ← 自定义名称
    type: nginx-ssh                # 部署器类型
    host: ""                       # 目标服务器 IP 或域名
    user: root                     # SSH 登录用户名
    password: ""                   # SSH 密码（与 ssh_key_path 二选一）
    # ssh_key_path: ~/.ssh/id_rsa  # SSH 私钥路径（与 password 二选一）
    cert_path: /etc/nginx/ssl      # 证书文件在远程服务器的存放目录
    reload_command: systemctl reload nginx  # 部署后重载 Nginx 的命令

  # 方式二：部署到阿里云 CDN
  aliyun-cdn:
    type: aliyun-cdn
    access_key_id: ""              # 阿里云 AccessKey ID
    access_key_secret: ""          # 阿里云 AccessKey Secret

  # 方式三：部署到腾讯云 CDN
  tencent-cdn:
    type: tencent-cdn
    secret_id: ""                  # 腾讯云 SecretId
    secret_key: ""                 # 腾讯云 SecretKey

# --- 证书列表 ---
# 每个条目定义一个需要管理的证书
certificates:
  # 示例：使用 DNS-01 验证的证书
  - domain: example.com            # 主域名（也是证书存储目录名）
    san:                           # 备用域名（可选，可多行）
      - www.example.com
      - api.example.com
    challenge: dns-01              # 验证方式: dns-01 或 http-01
    dns_provider: aliyun           # 对应 dns_providers 中的名称
    deploy_to:                     # 对应 deployers 中的名称（可多选）
      - my-nginx
      - aliyun-cdn

  # 示例：使用 HTTP-01 验证的证书
  - domain: another.com
    challenge: http-01             # HTTP 验证方式
    http_root: /var/www/html       # ← 网站根目录路径
                                   # Let's Encrypt 会在该目录下创建
                                   # .well-known/acme-challenge/ 验证文件
                                   # 确保该目录对 HTTP 请求可访问
    deploy_to:
      - my-nginx

# --- Web 管理界面 ---
web_ui:
  enabled: true
  host: 127.0.0.1                 # 监听地址
  port: 8088                      # 监听端口
  base_url: http://127.0.0.1:8088 # 外部访问地址
  session_secret: ""              # Session 加密密钥（随机字符串）
  admin_username: admin           # 管理员用户名
  admin_password_hash: ""         # 管理员密码哈希（通过 certkeeper register 生成）
